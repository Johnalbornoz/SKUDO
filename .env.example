# ─── SKUDO — Variables de entorno ───────────────────────────────────────────
# Copia este archivo a .env y rellena los valores.
# cp .env.example .env

# Base de datos (obligatorio para API y migraciones)
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/skudo

# Autenticación (obligatorio en producción; en desarrollo se usa un valor por defecto)
JWT_SECRET=un-secreto-largo-y-seguro-cambiar-en-produccion

# Puerto de la API (opcional; por defecto 3002)
# PORT=3002

# ─── Desarrollo local: login automático ────────────────────────────────────
# Si ALLOW_DEV_AUTO_SEED=true, al arrancar la API se fija la contraseña del usuario
# indicado para poder entrar con esas credenciales.
ALLOW_DEV_AUTO_SEED=true
DEV_LOGIN_EMAIL=admin@skudo.app
DEV_RESET_PASSWORD=Admin123!

# ─── Email (opcional; si no se configuran, los recordatorios se simulan en consola)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=SKUDO PSM <noreply@skudo.app>

# ─── Frontend (Vite) — evita "Failed to fetch" si la API está en otro origen
# En desarrollo con proxy suele dejarse vacío; en producción apuntar a la URL base de la API.
# VITE_API_BASE_URL=https://tu-api.ejemplo.com

# ─── Gemini / IA (obligatorio para finalizar diagnóstico, análisis documental, triangulación)
# Obtén tu API key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternativa (el backend también lee VITE_GEMINI_API_KEY si está definida)
# VITE_GEMINI_API_KEY=
